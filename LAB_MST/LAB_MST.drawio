  <diagram name="Page-1" id="--bG0002EXTSKLs7Wfnm">
    <mxGraphModel dx="1603" dy="2217" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="iyLxGsOgNWN4bAMZBOkI-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="Q2. Design an instagram like system with following requirements:&lt;div&gt;1. User Login Service&amp;nbsp;&lt;/div&gt;&lt;div&gt;2. Content Service&lt;/div&gt;&lt;div&gt;3. Feed Service&lt;/div&gt;&lt;div&gt;4. Follower Service&lt;/div&gt;&lt;div&gt;5. User Engagement Service&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Implement a mechanism to restrict the user for posting a non-policy compliance post.&lt;/div&gt;&lt;div&gt;Optimize the dynamic feed generation for the users.&lt;/div&gt;&lt;div&gt;Highlight the use of backfill service&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="700" x="110" y="110" as="geometry" />
        </mxCell>
        <mxCell id="iyLxGsOgNWN4bAMZBOkI-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="Functional Requirements:&lt;div&gt;1. User Should be able to Login and sign up.&lt;/div&gt;&lt;div&gt;2. User should be able to follow other users.&lt;/div&gt;&lt;div&gt;3. User should be able to post content&lt;/div&gt;&lt;div&gt;4. Feed should be generated for every user according to his/her followers&lt;/div&gt;&lt;div&gt;5. Users should be able to like/comment on posts.&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="330" x="110" y="270" as="geometry" />
        </mxCell>
        <mxCell id="iyLxGsOgNWN4bAMZBOkI-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="Non-functional Requirements:&lt;div&gt;1. Low Latency&lt;/div&gt;&lt;div&gt;2. Should be able to handle a large number of users (1M daily active users)&lt;/div&gt;&lt;div&gt;3. There should be filtering of posts according to policy compliance&lt;/div&gt;&lt;div&gt;4. Constant feed updation - backfill service&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="330" x="620" y="260" as="geometry" />
        </mxCell>
        <mxCell id="iyLxGsOgNWN4bAMZBOkI-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=16;" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;Api Designing:&lt;div&gt;1. GET /feed&lt;/div&gt;&lt;div&gt;2. POST /user&lt;/div&gt;&lt;div&gt;3. GET /user&lt;/div&gt;&lt;div&gt;4. GET /follower&lt;/div&gt;&lt;div&gt;5. POST /content&lt;/div&gt;&lt;div&gt;6.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="450" x="110" y="430" as="geometry" />
        </mxCell>
